        # ในระบบจริงต้องมีการยืนยันความปลอดภัยสูงมาก (Encryption/Digital Signature)
        response = requests.get(f"{self.government_api_url}/{user_id}")
        data = response.json()
        
        status = data.get("status") # 'alive', 'deceased', or 'newborn'
