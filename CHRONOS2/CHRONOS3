import requests # สมมติว่าใช้ดึงข้อมูลจาก API รัฐบาล
import time

class ChronosOracle:
    def __init__(self, contract_address):
        self.contract_address = contract_address
        self.government_api_url = "https://api.registration.go.th" # URL สมมติ

    def check_and_update(self, user_id):
